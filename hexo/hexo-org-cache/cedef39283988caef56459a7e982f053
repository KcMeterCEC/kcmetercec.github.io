br><span class=\"line\"></span><br><span class=\"line\"><span class=\"comment\">/*</span><br><span class=\"line\">  @note &#x5BF9;&#x5E94;&#x4E0A;&#x9762;&#x6CE8;&#x91CA;&#x7684;&#x8C03;&#x7528;&#x65B9;&#x5F0F;</span><br><span class=\"line\">  f = int_div;</span><br><span class=\"line\"> */</span></span><br><span class=\"line\">\tf = int_div();</span><br><span class=\"line\"></span><br><span class=\"line\">\t<span class=\"keyword\">if</span>(f)</span><br><span class=\"line\">\t\t<span class=\"built_in\">std</span>::<span class=\"built_in\">cout</span> &lt;&lt; f(<span class=\"number\">5</span>, <span class=\"number\">3</span>) &lt;&lt; <span class=\"built_in\">std</span>::endl;</span><br><span class=\"line\">\t<span class=\"keyword\">else</span></span><br><span class=\"line\">\t\t<span class=\"built_in\">std</span>::<span class=\"built_in\">cout</span> &lt;&lt; <span class=\"string\">&quot;f has no target, so it is undsafe to call&quot;</span> &lt;&lt; <span class=\"built_in\">std</span>::endl;</span><br><span class=\"line\"></span><br><span class=\"line\">\t<span class=\"comment\">//clear</span></span><br><span class=\"line\">\tf = <span class=\"number\">0</span>;</span><br><span class=\"line\"></span><br><span class=\"line\">\t<span class=\"keyword\">return</span> <span class=\"number\">0</span>;</span><br><span class=\"line\">}</span><br></pre></td></tr></table></figure>\n</div>\n</div>\n</div>\n<div id=\"outline-container-org66ab09b\" class=\"outline-3\">\n<h3 id=\"org66ab09b\">&#x5E38;&#x7528;&#x65B9;&#x5F0F;</h3>\n<div class=\"outline-text-3\" id=\"text-org66ab09b\">\n<div class=\"org-src-container\">\n<figure class=\"highlight cpp\"><table><tr><td class=\"code\"><pre><span class=\"line\"><span class=\"comment\">/* &#x7ED1;&#x5B9A;&#x4E00;&#x4E2A;&#x7C7B;&#x7684;&#x65B9;&#x6CD5;&#xFF0C;&#x7136;&#x540E;&#x5E94;&#x7528;&#x4E8E;&#x53E6;&#x4E00;&#x4E2A;&#x5BF9;&#x8C61; */</span></span><br><span class=\"line\"><span class=\"keyword\">struct</span> X{</span><br><spa