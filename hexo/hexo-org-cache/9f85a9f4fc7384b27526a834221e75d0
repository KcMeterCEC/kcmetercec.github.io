4;&#xFF0C;&#x4F46;&#x5982;&#x679C;&#x786C;&#x4EF6;&#x5E26;IOMMU,&#x5219;&#x4E5F;&#x53EF;&#x4EE5;&#x662F;&#x4E0D;&#x8FDE;&#x7EED;&#x7684;</span><br><span class=\"line\"> */</span></span><br><span class=\"line\"><span class=\"comment\">//&#x8FD4;&#x56DE;&#x7533;&#x8BF7;&#x5230;&#x7684;DMA&#x7F13;&#x51B2;&#x533A;&#x7684;&#x865A;&#x62DF;&#x5730;&#x5740;</span></span><br><span class=\"line\"><span class=\"comment\">//handle &#x4EE3;&#x8868;&#x603B;&#x7EBF;&#x5730;&#x5740;</span></span><br><span class=\"line\"><span class=\"function\"><span class=\"keyword\">void</span> *<span class=\"title\">dma_alloc_coherent</span><span class=\"params\">(<span class=\"keyword\">struct</span> device *dev, size_t size, dma_addr_t *handle, gfp_t gfp)</span></span>;</span><br><span class=\"line\"></span><br><span class=\"line\"><span class=\"comment\">//&#x91CA;&#x653E;&#x7533;&#x8BF7;&#x7684;&#x5185;&#x5B58;</span></span><br><span class=\"line\"><span class=\"function\"><span class=\"keyword\">void</span> <span class=\"title\">dma_free_coherent</span><span class=\"params\">(<span class=\"keyword\">struct</span> device *dev,size_t size, <span class=\"keyword\">void</span> *cpu_addr, dma_addr_t handle)</span></span>;</span><br><span class=\"line\"></span><br><span class=\"line\"><span class=\"comment\">/*</span><br><span class=\"line\">  &#x5206;&#x914D;&#x4E00;&#x4E2A;&#x5199;&#x5408;&#x5E76;(writecombining)&#x7684;DMA&#x7F13;&#x51B2;&#x533A;</span><br><span class=\"line\"> */</span></span><br><span class=\"line\"><span class=\"function\"><span class=\"keyword\">void</span> *<span class=\"title\">dma_alloc_writecombine</span><span class=\"params\">(<span class=\"keyword\">struct</span> device *dev, size_t size, dma_addr_t *handle, gfp_t gfp)</span></span>;</span><br><span class=\"line\"></span><br><span class=\"line\"><span class=\"comment\">//&#x91CA;&#x653E;</span></span><br><span class=\"line\"><span class=\"function\"><span class=\"keyword\">void</span> <span class=\"title\">dma_free_w