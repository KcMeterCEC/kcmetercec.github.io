aro-rpi-gnueabihf)\nset(CMAKE_C_COMPILER ${tools}/bin/arm-linux-gnueabihf-gcc)\nset(CMAKE_CXX_COMPILER ${tools}/bin/arm-linux-gnueabihf-g++)\n\n# &#x8BBE;&#x5B9A;&#x68C0;&#x67E5;&#x89C4;&#x5219;\nset(CMAKE_FIND_ROOT_PATH_MODE_PROGRAM NEVER)\nset(CMAKE_FIND_ROOT_PATH_MODE_LIBRARY ONLY)\nset(CMAKE_FIND_ROOT_PATH_MODE_INCLUDE ONLY)\nset(CMAKE_FIND_ROOT_PATH_MODE_PACKAGE ONLY)</pre>\n</div>\n</div>\n</div>\n</div>\n<div id=\"postamble\" class=\"status\">\nLast Updated 2020-06-28 Sun 11:59.<br>Render by <a href=\"https://github.com/CodeFalling/hexo-renderer-org\">hexo-renderer-org</a> with <a href=\"https://www.gnu.org/software/emacs/\">Emacs</a> 26.3 (<a href=\"https://orgmode.org\">Org</a> mode 9.3.7)\n</div>\n"}
