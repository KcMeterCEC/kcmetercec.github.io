\"line\">61</span><br><span class=\"line\">62</span><br><span class=\"line\">63</span><br><span class=\"line\">64</span><br><span class=\"line\">65</span><br><span class=\"line\">66</span><br><span class=\"line\">67</span><br><span class=\"line\">68</span><br><span class=\"line\">69</span><br></pre></td><td class=\"code\"><pre><span class=\"line\"><span class=\"preprocessor\">#<span class=\"keyword\">include</span> <span class=\"string\">&lt;uhd/utils/thread_priority.hpp&gt;</span></span></span><br><span class=\"line\"><span class=\"preprocessor\">#<span class=\"keyword\">include</span> <span class=\"string\">&lt;uhd/utils/safe_main.hpp&gt;</span></span></span><br><span class=\"line\"><span class=\"preprocessor\">#<span class=\"keyword\">include</span> <span class=\"string\">&lt;uhd/usrp/multi_usrp.hpp&gt;</span></span></span><br><span class=\"line\"><span class=\"preprocessor\">#<span class=\"keyword\">include</span> <span class=\"string\">&lt;uhd/exception.hpp&gt;</span></span></span><br><span class=\"line\"><span class=\"preprocessor\">#<span class=\"keyword\">include</span> <span class=\"string\">&lt;uhd/types/tune_request.hpp&gt;</span></span></span><br><span class=\"line\"><span class=\"preprocessor\">#<span class=\"keyword\">include</span> <span class=\"string\">&lt;boost/program_options.hpp&gt;</span></span></span><br><span class=\"line\"><span class=\"preprocessor\">#<span class=\"keyword\">include</span> <span class=\"string\">&lt;boost/format.hpp&gt;</span></span></span><br><span class=\"line\"><span class=\"preprocessor\">#<span class=\"keyword\">include</span> <span class=\"string\">&lt;boost/thread.hpp&gt;</span></span></span><br><span class=\"line\"><span class=\"preprocessor\">#<span class=\"keyword\">include</span> <span class=\"string\">&lt;iostream&gt;</span></span></span><br><span class=\"line\"></span><br><span class=\"line\"><span class=\"function\"><span class=\"keyword\">int</span> <span class=\"title\">UHD_SAFE_MAIN</span><span class=\"param