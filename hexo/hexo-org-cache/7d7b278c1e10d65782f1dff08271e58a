ot;type&quot;</span>) and hine[<span class=\"string\">&quot;type&quot;</span>] != <span class=\"string\">&quot;b200&quot;</span>) <span class=\"keyword\">return</span> b200_addrs;</span><br><span class=\"line\">\t<span class=\"comment\">//return an empty list of addresses when an address or resource is specified,</span></span><br><span class=\"line\">\t<span class=\"comment\">//since an address and resource is intended for a different, non-USB,device,</span></span><br><span class=\"line\">\tBOOST_FOREACH(<span class=\"keyword\">device_addr_t</span> hint_i, separate_device_addr(hint)){</span><br><span class=\"line\">\t\t<span class=\"keyword\">if</span>(hint_i.has_key(<span class=\"string\">&quot;addr&quot;</span>) || hint_i.has_key(<span class=\"string\">&quot;resource&quot;</span>)) <span class=\"keyword\">return</span> b200_addrs;</span><br><span class=\"line\">\t}</span><br><span class=\"line\">\t<span class=\"comment\">//Important note:</span></span><br><span class=\"line\">\t<span class=\"comment\">//The get device list calls are nested inside the for loop.</span></span><br><span class=\"line\">\t<span class=\"comment\">// This allows the udb guts to decontruct when not in use,</span></span><br><span class=\"line\">\t<span class=\"comment\">// so that re-enumeration after fw load can occur successfully.</span></span><br><span class=\"line\">\t<span class=\"comment\">// This requirement is a courtesy of libusb1.0 on windows</span></span><br><span class=\"line\">\t<span class=\"comment\">// &#x53D1;&#x73B0;&#x8BBE;&#x5907;&#xFF0C;&#x5E76;&#x7ED9;usb&#x8BBE;&#x5907;&#x4E0B;&#x8F7D;&#x56FA;&#x4EF6;</span></span><br><span class=\"line\">\t<span class=\"keyword\">size_t</span> found = <span class=\"number\">0</span>;</span><br><span class=\"line\">\tBOOST_FOREACH(usb_device_handle::sptr handle, get_b200_device_handles(hint)){</span><br><span class=\"line\">\t\t<span class=\"comment\">//extract the firmware path for the b200</span></span><br><span class=\"line\">\t\t<