ms\">(_device_mutex)</span></span>;</span><br><span class=\"line\"></span><br><span class=\"line\">\t<span class=\"comment\">/// &#x7533;&#x660E;&#x4E00;&#x4E2A;&#x5143;&#x7EC4;&#xFF0C;&#x5305;&#x542B;&#x5730;&#x5740;&#x548C;&#x5BF9;&#x5E94;&#x7684; make &#x65B9;&#x6CD5;</span></span><br><span class=\"line\">\t<span class=\"keyword\">typedef</span> boost::tuple&lt;<span class=\"keyword\">device_addr_t</span>, <span class=\"keyword\">make_t</span>&gt; <span class=\"keyword\">device_addr_make_t</span>;</span><br><span class=\"line\">\t<span class=\"comment\">/// &#x5B9A;&#x4E49;&#x4E00;&#x4E2A;&#x52A8;&#x6001;&#x6570;&#x7EC4;&#xFF0C;&#x6BCF;&#x4E2A;&#x5143;&#x7D20;&#x90FD;&#x662F;&#x4E00;&#x4E2A;&#x5143;&#x7EC4;</span></span><br><span class=\"line\">\t<span class=\"built_in\">std</span>::<span class=\"built_in\">vector</span>&lt;<span class=\"keyword\">dev_addr_make_t</span>&gt; dev_addr_makers;</span><br><span class=\"line\"></span><br><span class=\"line\">\t<span class=\"comment\">/// &#x83B7;&#x53D6;&#x8BBE;&#x5907;&#x5BB9;&#x5668;&#x4E2D;&#x7684;&#x4E00;&#x4E2A;&#x5143;&#x7D20;&#xFF0C;&#x4E5F;&#x5C31;&#x662F;&#x83B7;&#x53D6;&#x6CE8;&#x518C;&#x5230;&#x7684;&#x4E00;&#x4E2A;&#x8BBE;&#x5907;&#x63CF;&#x8FF0;</span></span><br><span class=\"line\">\tBOOST_FOREACH(<span class=\"keyword\">const</span> <span class=\"keyword\">dev_fcn_reg_t</span> &amp;fcn, get_dev_fcn_regs()){</span><br><span class=\"line\">\t\t<span class=\"keyword\">try</span>{</span><br><span class=\"line\">\t\t\t<span class=\"comment\">///&#x5982;&#x679C;&#x7C7B;&#x578B;&#x76F8;&#x7B49;&#xFF0C;&#x90A3;&#x4E48;&#x5C31;&#x8C03;&#x7528;&#x5BF9;&#x5E94;&#x8BBE;&#x5907;&#x7684;find&#x65B9;&#x6CD5;</span></span><br><span class=\"line\">\t\t\t<span class=\"keyword\">if</span>(filter == ANY or fcn.get&lt;<span class=\"number\">2</span>&gt; == filter){</span><br><span class=\"line\">\t\t\t\tBOOST_FOREACH(<span class=\"keyword\">device_addr_t</span> dev_addr, fcn.get&lt;<span class=\"number\">0</span>&gt;()(hint)